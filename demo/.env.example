# cp .env.example .env 후 본인 로컬 값으로 채우세요.

# DataSource (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=summerbag
DB_USERNAME=postgres
DB_PASSWORD=postgres

# 앱인토스(Toss) 연동
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# OpenWeatherMap 연동
OPENWEATHER_API_KEY=

# AI 추천 연동 (프롬프트 엔지니어링, 저렴한 모델 API 키)
AI_API_KEY=